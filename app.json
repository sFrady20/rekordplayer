{
  "expo": {
    "name": "rekordplay",
    "slug": "rekordplay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-new.png",
    "scheme": "rekordplay",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#121212",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#061912",
        "foregroundImage": "./assets/icon-new-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.internal.rekordplay"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#121212",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-audio",
        {
          "supportsBackgroundPlayback": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
